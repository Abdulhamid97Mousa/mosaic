# MANIFEST.in for mosaic-platform
# This file controls what gets included/excluded in the PyPI distribution

# =============================================================================
# INCLUDE - Essential files
# =============================================================================

include LICENSE
include README.md
include pyproject.toml
include MANIFEST.in
include .env.example

# Include requirements files
recursive-include requirements *.txt *.md

# Include metadata directory
recursive-include metadata *

# Include experiment configs (small)
recursive-include experiments *.py *.yaml *.yml *.json

# =============================================================================
# EXCLUDE - Documentation (heavy, hosted on ReadTheDocs)
# =============================================================================

prune docs

# =============================================================================
# EXCLUDE - Development/IDE files
# =============================================================================

prune .claude
prune .cursor
prune .pytest_cache
prune .venv
prune .git

# =============================================================================
# EXCLUDE - 3rd party directories NOT needed in PyPI package
# =============================================================================

# Deprecated/internal workers
prune 3rd_party/workers/DI-engine
prune 3rd_party/workers/unreal_map_worker
prune 3rd_party/workers/godot_worker

# Submodule directories (users install via pip)
prune 3rd_party/tools/Syllabus

# =============================================================================
# INCLUDE - Essential 3rd party workers (Python packages only)
# =============================================================================

# Include only the Python source files for workers
recursive-include 3rd_party/workers/balrog_worker *.py
recursive-include 3rd_party/workers/chess_worker *.py
recursive-include 3rd_party/workers/cleanrl_worker *.py
recursive-include 3rd_party/workers/jumanji_worker *.py
recursive-include 3rd_party/workers/llm_game_worker *.py
recursive-include 3rd_party/workers/marllib_worker *.py
recursive-include 3rd_party/workers/mctx_worker *.py
recursive-include 3rd_party/workers/mosaic *.py
recursive-include 3rd_party/environments/mosaic_multigrid *.py
recursive-include 3rd_party/workers/mujoco_mpc_worker *.py
recursive-include 3rd_party/environments/multigrid-ini *.py
recursive-include 3rd_party/workers/pettingzoo_worker *.py
recursive-include 3rd_party/environments/procgen *.py
recursive-include 3rd_party/workers/ray_worker *.py
recursive-include 3rd_party/tools/shimmy *.py
recursive-include 3rd_party/workers/stockfish_worker *.py
recursive-include 3rd_party/workers/xuance_worker *.py

# =============================================================================
# EXCLUDE - Test cache and build artifacts
# =============================================================================

global-exclude *.pyc
global-exclude *.pyo
global-exclude __pycache__
global-exclude *.egg-info
global-exclude .DS_Store
global-exclude *.so
global-exclude *.dll
global-exclude *.dylib

# =============================================================================
# EXCLUDE - Runtime artifacts
# =============================================================================

prune var
prune logs
prune build
prune dist
